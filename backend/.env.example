# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Any long random string — used to sign auth JWTs
JWT_SECRET=

# Google OAuth Client ID (Web application) — optional, enables "Continue with Google".
# Create one at https://console.cloud.google.com/ -> APIs & Services -> Credentials.
# Leave blank to run without Google sign-in.
GOOGLE_CLIENT_ID=
